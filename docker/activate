#
# Source this file (don't execute it) for a Python-venv-like dev experience
# that runs commands inside the COMPASS docker container.
#
#   source ./docker/activate         # sets up shim PATH + (compass-rl) prompt prefix
#   python run.py …                  # actually runs inside the container
#   deactivate                       # revert
#
# What it does:
#   1. Ensures the container is running (./docker/run.sh up).
#   2. Generates a tmp dir of shim scripts for python / pip / etc. and prepends
#      it to PATH. Each shim `docker exec`s the same-named binary inside the
#      container, with the host CWD translated to the container path.
#   3. Adds a `(compass-rl) ` prefix to PS1 so you know you're activated.
#   4. Defines a `deactivate` function to revert (1)-(3) and clean up the shim dir.
#
# The container itself keeps running until you call `./docker/run.sh down`.
# `deactivate` only tears down the shim PATH; multiple shells can be activated
# against the same container concurrently.

# Detect the directory containing this script. Works under bash (BASH_SOURCE)
# and zsh (use ${(%):-%N} fallback — sourced filename).
if [ -n "${BASH_SOURCE:-}" ]; then
    _compass_activate_path="${BASH_SOURCE[0]}"
elif [ -n "${ZSH_VERSION:-}" ]; then
    # shellcheck disable=SC2296
    _compass_activate_path="${(%):-%N}"
else
    echo "[activate] Unsupported shell: source from bash or zsh" >&2
    return 1 2>/dev/null || exit 1
fi
_COMPASS_REPO_ROOT="$(cd "$(dirname "${_compass_activate_path}")/.." && pwd)"
unset _compass_activate_path

# Path the host repo is bind-mounted to inside the container — must match
# CONT_REPO_DIR in docker/run.sh.
_COMPASS_CONT_REPO_DIR="/workspace/COMPASS"

# Pull container name + image tag from run.sh so the two stay in sync.
_COMPASS_CONTAINER="$(
    REPO_ROOT="${_COMPASS_REPO_ROOT}" bash -c '
        cd "${REPO_ROOT}"
        repo_hash=$(printf "%s" "${REPO_ROOT}" | sha1sum | cut -c1-8)
        echo "compass-$(id -un)-${repo_hash}"
    '
)"

# Bring the container up if it isn't already.
if ! "${_COMPASS_REPO_ROOT}/docker/run.sh" up; then
    echo "[activate] Failed to bring up container; aborting." >&2
    unset _COMPASS_REPO_ROOT _COMPASS_CONTAINER
    return 1 2>/dev/null || exit 1
fi

# Tmp shim dir, removed by `deactivate`.
_COMPASS_SHIM_DIR="$(mktemp -d "${TMPDIR:-/tmp}/compass-shims.XXXXXX")"

# Shimmed commands. To add another tool, append it here — no other wiring needed.
_compass_shim_cmds=(
    python python3
    pip pip3
    isaaclab.sh
    tensorboard
    pytest
    yapf pylint
    pre-commit
)

# Generate one shim script per command. Each is a tiny bash wrapper that
# translates the host CWD into the container path before exec'ing.
#
# The python / python3 shims additionally check whether the script being
# launched carries a `# COMPASS_HOST_SIDE: true` marker in its first 50 lines.
# If so, the shim execs host Python instead of routing into the container —
# this is the escape hatch for launchers (osmo/run_osmo.py, osmo/run_benchmark.py)
# that need `docker` and `osmo` CLIs, which only exist on the host.
# Note: only file-path invocation is supported (`python script.py …`), not
# `python -m module`.
for _cmd in "${_compass_shim_cmds[@]}"; do
    case "${_cmd}" in
        python|python3)
            _host_bypass_block='
# Host-side bypass: scan argv for a .py file carrying the
# `# COMPASS_HOST_SIDE: true` marker; if found, exec host Python.
for _arg in "$@"; do
    case "$_arg" in
        -*) continue ;;
        *.py)
            if [ -f "$_arg" ] && head -n 50 "$_arg" 2>/dev/null \
                    | grep -qE "^# COMPASS_HOST_SIDE: true"; then
                exec /usr/bin/python3 "$@"
            fi
            break ;;
        *) break ;;
    esac
done
'
            ;;
        *)
            _host_bypass_block=''
            ;;
    esac
    cat > "${_COMPASS_SHIM_DIR}/${_cmd}" <<EOF
#!/usr/bin/env bash
# Auto-generated by docker/activate; removed on \`deactivate\`.
set -eu
${_host_bypass_block}
host_pwd="\$(pwd)"
case "\${host_pwd}" in
    "${_COMPASS_REPO_ROOT}"|"${_COMPASS_REPO_ROOT}"/*)
        cont_pwd="${_COMPASS_CONT_REPO_DIR}\${host_pwd#${_COMPASS_REPO_ROOT}}"
        ;;
    *)
        cont_pwd="${_COMPASS_CONT_REPO_DIR}"
        ;;
esac

# stdin tty: -t for interactive sessions (REPL, tensorboard hot keys); fall back
# to -i alone when stdin isn't a tty (CI, piped input).
if [ -t 0 ] && [ -t 1 ]; then
    docker_flags="-it"
else
    docker_flags="-i"
fi

exec docker exec \${docker_flags} \\
    -w "\${cont_pwd}" \\
    -e "WANDB_API_KEY=\${WANDB_API_KEY:-}" \\
    -e "HF_TOKEN=\${HF_TOKEN:-}" \\
    -e "DISPLAY=\${DISPLAY:-}" \\
    "${_COMPASS_CONTAINER}" \\
    ${_cmd} "\$@"
EOF
    chmod +x "${_COMPASS_SHIM_DIR}/${_cmd}"
done
unset _cmd _compass_shim_cmds _host_bypass_block

# Stash + rewrite PATH and PS1.
_COMPASS_OLD_PATH="${PATH}"
export PATH="${_COMPASS_SHIM_DIR}:${PATH}"
_COMPASS_OLD_PS1="${PS1:-}"
export PS1="(compass-rl) ${PS1:-\$ }"

# Public deactivate function. Reverses everything this script did.
deactivate() {
    if [ -n "${_COMPASS_OLD_PATH:-}" ]; then
        export PATH="${_COMPASS_OLD_PATH}"
    fi
    if [ -n "${_COMPASS_OLD_PS1+x}" ]; then
        export PS1="${_COMPASS_OLD_PS1}"
    fi
    if [ -n "${_COMPASS_SHIM_DIR:-}" ] && [ -d "${_COMPASS_SHIM_DIR}" ]; then
        rm -rf "${_COMPASS_SHIM_DIR}"
    fi
    unset _COMPASS_OLD_PATH _COMPASS_OLD_PS1 _COMPASS_SHIM_DIR \
          _COMPASS_REPO_ROOT _COMPASS_CONTAINER _COMPASS_CONT_REPO_DIR
    unset -f deactivate
    echo "[compass-rl] Deactivated. (Container is still running; run ./docker/run.sh down to stop it.)"
}

echo "[compass-rl] Activated. Run \`deactivate\` to leave; container: ${_COMPASS_CONTAINER}"
